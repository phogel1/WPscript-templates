{
  "manufacturer": "Swegon",
  "model": "REACT GMB (Gruner damper actuator)",
  "category": "Other",
  "version": "2026-05-04",
  "source": "swegon react modbus.pdf (Gruner — Modbus-inställningar, 20231207)",
  "sourceVersion": "20231207",
  "notes": "Täcker hela Swegon REACT-familjen av VAV/CAV-spjäll med Gruner GMB-aktuator (RTU RS-485, FC 03h läs / 06h skriv enskilt holdingadress). En enda templat används för alla 7 varianter — välj rätt aktuator i variant-dropdownen. Varianterna: V GMB (variabelflöde, 327VM-...-MB-SWEV), P GMB (tryck, 327VM-...-MB-SWEP), ALS GMB (anslutningslåda VAV, 309VM-024-150-MB), M GMB (mätenhet, GT-VM-DD3-MB — endast flödesmätning, inga setpoint-/positionsregister), V-SR GMB (variabelflöde med fjäderåtergång, GUAC-DM3-MB), PX GMB (tryck 300 Pa, GUAC-PM-DD3-MB), PX-SR GMB (tryck med fjäderåtergång). Adresser delas mellan varianter — beskrivningarna är generiska 'flöde/tryck' eftersom samma register betyder olika sak beroende på modell. Skala: alla 0..10000 = 0..100% (förutom register 7/120/121 = 0..65535 i vald enhet, register 10 mV = 0..10000). Standard slave-ID är 1, kommunikation 19200 8E1 (displayinställning 14). Adressering: alla register är holdingadresser → WebPort 4xxxx-prefix används (register 0 = 40001, register 130 = 40131, etc).",
  "defaultDevicePrefix": "VAV01",

  "tags": {
    "sp":               { "name": "{prefix}_SP",            "device": "{prefix}", "address": "40001", "datatype": "UINT", "rawmin": 0,    "rawmax": 10000, "engmin": 0,     "engmax": 100,   "unit": "%",  "format": "0",   "description": "Börvärde flöde/tryck (% av Vmin/Vmax eller Pmin/Pmax)", "alarmoptions": "", "trendoptions": "es:0" },
    "override":         { "name": "{prefix}_OVERRIDE_CMD",  "device": "{prefix}", "address": "40002", "datatype": "UINT", "rawmin": 0,    "rawmax": 8,     "engmin": 0,     "engmax": 8,     "unit": "",   "format": "0",   "description": "Tvångsstyrning (0=Auto,1=Öppet,2=Stängt,3=Min,4=Max,5=Mellan,6=Snabbt öppet,7=Snabbt stängt,8=Stopp)", "alarmoptions": "", "trendoptions": "" },
    "pos_rel":          { "name": "{prefix}_POS_PV",        "device": "{prefix}", "address": "40005", "datatype": "UINT", "rawmin": 0,    "rawmax": 10000, "engmin": 0,     "engmax": 100,   "unit": "%",  "format": "0",   "description": "Aktuell spjällposition (relativ %)", "alarmoptions": "", "trendoptions": "es:0" },
    "pos_abs":          { "name": "{prefix}_POS_DEG_PV",    "device": "{prefix}", "address": "40006", "datatype": "UINT", "rawmin": 0,    "rawmax": 10000, "engmin": 0,     "engmax": 100,   "unit": "°",  "format": "0",   "description": "Aktuell spjällposition (grader)", "alarmoptions": "", "trendoptions": "es:0" },
    "meas_pct":         { "name": "{prefix}_PCT_PV",        "device": "{prefix}", "address": "40007", "datatype": "UINT", "rawmin": 0,    "rawmax": 10000, "engmin": 0,     "engmax": 100,   "unit": "%",  "format": "0",   "description": "Aktuellt flöde/tryck (% av nominellt)", "alarmoptions": "", "trendoptions": "es:0" },
    "meas_abs":         { "name": "{prefix}_PV",            "device": "{prefix}", "address": "40008", "datatype": "UINT", "rawmin": 0,    "rawmax": 65535, "engmin": 0,     "engmax": 65535, "unit": "",   "format": "0",   "description": "Aktuellt flöde/tryck (vald enhet — l/s, m³/h, cfm, Pa, inWC)", "alarmoptions": "", "trendoptions": "es:0" },
    "feedback":         { "name": "{prefix}_FB_MV",         "device": "{prefix}", "address": "40011", "datatype": "UINT", "rawmin": 0,    "rawmax": 10000, "engmin": 0,     "engmax": 10000, "unit": "mV", "format": "0",   "description": "Återkopplingssignal (0(2)–10 V i mV)", "alarmoptions": "", "trendoptions": "es:0" },

    "vmin_pct":         { "name": "{prefix}_MIN_PCT_SP",    "device": "{prefix}", "address": "40106", "datatype": "UINT", "rawmin": 0,    "rawmax": 10000, "engmin": 0,     "engmax": 100,   "unit": "%",  "format": "0",   "description": "Min flöde/tryck (% av nominellt — Vmin/Pmin)", "alarmoptions": "", "trendoptions": "" },
    "vmax_pct":         { "name": "{prefix}_MAX_PCT_SP",    "device": "{prefix}", "address": "40107", "datatype": "UINT", "rawmin": 0,    "rawmax": 10000, "engmin": 0,     "engmax": 100,   "unit": "%",  "format": "0",   "description": "Max flöde/tryck (% av nominellt — Vmax/Pmax)", "alarmoptions": "", "trendoptions": "" },
    "failsafe_pos":     { "name": "{prefix}_FAIL_POS_SP",   "device": "{prefix}", "address": "40109", "datatype": "UINT", "rawmin": 0,    "rawmax": 5,     "engmin": 0,     "engmax": 5,     "unit": "",   "format": "0",   "description": "Position vid kommunikationsbortfall (0=Senaste,1=Stänger,2=Öppnar,3=Min,4=Mellan,5=Max)", "alarmoptions": "", "trendoptions": "" },
    "failsafe_timeout": { "name": "{prefix}_FAIL_TO_SP",    "device": "{prefix}", "address": "40110", "datatype": "UINT", "rawmin": 0,    "rawmax": 65535, "engmin": 0,     "engmax": 65535, "unit": "s",  "format": "0",   "description": "Timeout för kommunikationsbortfall (s) — endast V GMB / P GMB", "alarmoptions": "", "trendoptions": "" },
    "vmin_abs":         { "name": "{prefix}_MIN_SP",        "device": "{prefix}", "address": "40121", "datatype": "UINT", "rawmin": 0,    "rawmax": 65535, "engmin": 0,     "engmax": 65535, "unit": "",   "format": "0",   "description": "Min flöde/tryck (i vald enhet)", "alarmoptions": "", "trendoptions": "" },
    "vmax_abs":         { "name": "{prefix}_MAX_SP",        "device": "{prefix}", "address": "40122", "datatype": "UINT", "rawmin": 0,    "rawmax": 65535, "engmin": 0,     "engmax": 65535, "unit": "",   "format": "0",   "description": "Max flöde/tryck (i vald enhet)", "alarmoptions": "", "trendoptions": "" },
    "sp_mode":          { "name": "{prefix}_SP_MODE",       "device": "{prefix}", "address": "40123", "datatype": "UINT", "rawmin": 0,    "rawmax": 3,     "engmin": 0,     "engmax": 3,     "unit": "",   "format": "0",   "description": "Börvärde-/återkopplingsläge (0=Analog-Analog,1=Modbus-Analog,2=Modbus-Modbus,3=Analog-Modbus)", "alarmoptions": "", "trendoptions": "" },
    "modbus_addr":      { "name": "{prefix}_MB_ADDR",       "device": "{prefix}", "address": "40131", "datatype": "UINT", "rawmin": 1,    "rawmax": 247,   "engmin": 1,     "engmax": 247,   "unit": "",   "format": "0",   "description": "Modbus slave-ID (1–247)", "alarmoptions": "", "trendoptions": "" },
    "unit_selector":    { "name": "{prefix}_UNIT_SEL",      "device": "{prefix}", "address": "40202", "datatype": "UINT", "rawmin": 0,    "rawmax": 6,     "engmin": 0,     "engmax": 6,     "unit": "",   "format": "0",   "description": "Enhetsväljare (0=l/s, 1=m³/h, 2=Pa, 3=inWC/1000, 6=cfm)", "alarmoptions": "", "trendoptions": "" },
    "function_bits":    { "name": "{prefix}_FUNC_BITS",     "device": "{prefix}", "address": "40552", "datatype": "UINT", "rawmin": 0,    "rawmax": 65535, "engmin": 0,     "engmax": 65535, "unit": "",   "format": "0",   "description": "Funktionsbitar (bit0: 0=0–10V, 1=2–10V; bit6: gångriktning CW/CCW)", "alarmoptions": "", "trendoptions": "" }
  },

  "base": [
    "meas_pct", "meas_abs", "feedback",
    "vmin_pct", "vmax_pct", "vmin_abs", "vmax_abs",
    "modbus_addr", "unit_selector"
  ],

  "config": [
    {
      "id": "variant",
      "type": "dropdown",
      "label": "REACT-variant",
      "help": "Välj rätt aktuator. Adresser delas mellan varianter — variantval styr vilka extra register som tas in (setpoint, position, failsafe). M är endast en mätenhet utan reglering.",
      "default": "v",
      "options": [
        { "id": "v",     "label": "REACT V GMB — variabelflöde (327VM-024-XX-MB-SWEV)",        "tags": ["sp", "override", "pos_rel", "pos_abs", "failsafe_pos", "failsafe_timeout"] },
        { "id": "v_sr",  "label": "REACT V-SR GMB — variabelflöde, fjäderåtergång (GUAC-DM3-MB)", "tags": ["sp", "override", "pos_rel", "pos_abs", "failsafe_pos"] },
        { "id": "p",     "label": "REACT P GMB — tryckreglering 500 Pa (327VM-024-XX-MB-SWEP)", "tags": ["sp", "override", "pos_rel", "pos_abs", "failsafe_pos", "failsafe_timeout"] },
        { "id": "px",    "label": "REACT PX GMB — tryckreglering 300 Pa (GUAC-PM-DD3-MB)",      "tags": ["sp", "override", "pos_rel", "pos_abs", "failsafe_pos"] },
        { "id": "px_sr", "label": "REACT PX-SR GMB — tryckreglering, fjäderåtergång",            "tags": ["sp", "override", "pos_rel", "pos_abs", "failsafe_pos"] },
        { "id": "als",   "label": "REACT ALS GMB — anslutningslåda VAV (309VM-024-150-MB)",     "tags": ["sp", "override", "pos_rel", "pos_abs", "failsafe_pos"] },
        { "id": "m",     "label": "REACT M GMB — mätenhet, endast flödesmätning (GT-VM-DD3-MB)", "tags": [] }
      ]
    },
    {
      "id": "config_extras",
      "type": "multiselect",
      "label": "Konfigurationsregister (driftsättning)",
      "help": "Permanenta inställningar — användbara vid driftsättning, sällan i daglig drift.",
      "options": [
        { "id": "sp_mode",   "label": "Börvärde-/återkopplingsläge (Analog/Modbus)",         "default": false, "tags": ["sp_mode"] },
        { "id": "func_bits", "label": "Funktionsbitar (signaltyp 0–10/2–10 V, gångriktning)", "default": false, "tags": ["function_bits"] }
      ]
    }
  ]
}
