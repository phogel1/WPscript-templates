      "default": "heat_cool_vav",
      "options": [
        { "id": "heat",            "label": "Värme",                                  "tags": [] },
        { "id": "cool",            "label": "Kyla",                                   "tags": [] },
        { "id": "heat_cool",       "label": "Värme + Kyla (4-rörs)",                  "tags": [] },
        { "id": "changeover",      "label": "Värme/Kyla change-over (2-rörs)",        "tags": ["co_temp_pv", "co_state", "co_diff_heat", "co_diff_cool"] },
        { "id": "heat_cool_vav",   "label": "Värme + Kyla + VAV (3-rörs/chilled beam)", "tags": ["vav_min", "vav_max", "vav_max_heat", "vav_min_stby", "vav_min_unocc"] },
        { "id": "heat_vav",        "label": "Värme + VAV",                            "tags": ["vav_min", "vav_max", "vav_max_heat"] },
        { "id": "vav_only",        "label": "Endast VAV",                             "tags": ["vav_min", "vav_max", "vav_min_stby", "vav_min_unocc", "vav_min_off"] },
        { "id": "co_vav",          "label": "Change-over + VAV",                      "tags": ["co_temp_pv", "co_state", "co_diff_heat", "co_diff_cool", "vav_min", "vav_max"] }
      ]
    },
    {
