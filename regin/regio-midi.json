  "base": [
    "room_temp_pv",
    "sp_heat", "sp_cool",
    "sp_offset", "sp_active",
    "unit_state", "ctrl_state",
    "heat_op", "cool_op",
    "presence",
    "bypass_cmd"
  ],

  "config": [
    {
      "id": "model_variant",
      "type": "dropdown",
      "label": "Regulator-modell",
      "help": "Välj exakt hårdvarumodell. Alla 14 modellerna delar samma firmware (Regio Midi v1.7) och samma Modbus-karta — valet styr främst vilka av nedanstående dropdowns som är relevanta. Hjälptexten under modellnamnet visar vilka funktioner som faktiskt finns i hårdvaran. '-BLACK'-varianter är samma som motsvarande icke-svart modell.",
      "default": "rcc-c3docs",
      "options": [
        { "id": "rcc-c3docs", "label": "RCC-C3DOCS — inbyggd CO₂ + display + närvaroknapp + EC-fläkt", "tags": [],
          "presets": { "ctrl_mode": "heat_cool_vav", "air_quality": ["co2", "co2_setpoints"], "fan_control": "ec",    "outputs": ["heat_full", "cool_full", "vav_full"] } },
        { "id": "rcc-c3hcs",  "label": "RCC-C3HCS — inbyggd CO₂ + dolt börvärde + EC-fläkt (ingen display)", "tags": [],
          "presets": { "ctrl_mode": "heat_cool_vav", "air_quality": ["co2", "co2_setpoints"], "fan_control": "ec",    "outputs": ["heat_full", "cool_full", "vav_full"] } },
        { "id": "rc-c3doc",   "label": "RC-C3DOC — extern CO₂ (AI2) + display + närvaroknapp + EC-fläkt",  "tags": [],
          "presets": { "ctrl_mode": "heat_cool_vav", "air_quality": ["co2", "co2_setpoints"], "fan_control": "ec",    "outputs": ["heat_full", "cool_full", "vav_full"] } },
        { "id": "rc-c3dfoc",  "label": "RC-C3DFOC — extern CO₂ + display + närvaroknapp + EC-fläkt med fläktomkopplare", "tags": [],
          "presets": { "ctrl_mode": "heat_cool_vav", "air_quality": ["co2", "co2_setpoints"], "fan_control": "ec",    "outputs": ["heat_full", "cool_full", "vav_full"] } },
        { "id": "rc-c3",      "label": "RC-C3 — bas, EC-fläkt, börvärdesratt (ingen display, ingen CO₂)", "tags": [],
          "presets": { "ctrl_mode": "heat_cool_vav", "air_quality": [],                       "fan_control": "ec",    "outputs": ["heat_full", "cool_full", "vav_full"] } },
        { "id": "rc-c3h",     "label": "RC-C3H — EC-fläkt + dolt börvärde (ingen display, ingen CO₂)",   "tags": [],
          "presets": { "ctrl_mode": "heat_cool_vav", "air_quality": [],                       "fan_control": "ec",    "outputs": ["heat_full", "cool_full", "vav_full"] } },
        { "id": "rc-c3o",     "label": "RC-C3O — EC-fläkt + närvaroknapp + börvärdesratt (ingen display)", "tags": [],
          "presets": { "ctrl_mode": "heat_cool_vav", "air_quality": [],                       "fan_control": "ec",    "outputs": ["heat_full", "cool_full", "vav_full"] } },
        { "id": "rc-cf",      "label": "RC-CF — 3-stegs fläkt (DO1-DO3) + börvärdesratt (ingen display)", "tags": [],
          "presets": { "ctrl_mode": "heat_cool",     "air_quality": [],                       "fan_control": "step3", "outputs": ["heat_full", "cool_full"] } },
        { "id": "rc-cfo",     "label": "RC-CFO — 3-stegs fläkt + närvaroknapp + börvärdesratt (ingen display)", "tags": [],
          "presets": { "ctrl_mode": "heat_cool",     "air_quality": [],                       "fan_control": "step3", "outputs": ["heat_full", "cool_full"] } },
        { "id": "rc-cdfo",    "label": "RC-CDFO — 3-stegs fläkt + närvaroknapp + display",               "tags": [],
          "presets": { "ctrl_mode": "heat_cool",     "air_quality": [],                       "fan_control": "step3", "outputs": ["heat_full", "cool_full"] } },
        { "id": "rc-ct",      "label": "RC-CT — 3-punkt (DO1-DO5, inga analoga utgångar) + börvärdesratt", "tags": [],
          "presets": { "ctrl_mode": "heat_cool",     "air_quality": [],                       "fan_control": "none",  "outputs": ["heat_full", "cool_full"] } },
        { "id": "rc-cth",     "label": "RC-CTH — 3-punkt + dolt börvärde (ingen display)",               "tags": [],
          "presets": { "ctrl_mode": "heat_cool",     "air_quality": [],                       "fan_control": "none",  "outputs": ["heat_full", "cool_full"] } },
        { "id": "rc-cto",     "label": "RC-CTO — 3-punkt + närvaroknapp + börvärdesratt",                "tags": [],
          "presets": { "ctrl_mode": "heat_cool",     "air_quality": [],                       "fan_control": "none",  "outputs": ["heat_full", "cool_full"] } },
        { "id": "rc-cdto",    "label": "RC-CDTO — 3-punkt + närvaroknapp + display",                     "tags": [],
          "presets": { "ctrl_mode": "heat_cool",     "air_quality": [],                       "fan_control": "none",  "outputs": ["heat_full", "cool_full"] } }
      ]
    },
    {
      "id": "ctrl_mode",
      "type": "dropdown",
      "label": "Reglerläge",
      "help": "Hur enheten reglerar värme/kyla/luftflöde. Påverkar vilka utgångar som används.",
      "default": "heat_cool_vav",
      "options": [
        { "id": "heat",            "label": "Värme",                                  "tags": [] },
        { "id": "cool",            "label": "Kyla",                                   "tags": [] },
        { "id": "heat_cool",       "label": "Värme + Kyla (4-rörs)",                  "tags": [] },
        { "id": "changeover",      "label": "Värme/Kyla change-over (2-rörs)",        "tags": ["co_temp_pv", "co_state", "co_diff_heat", "co_diff_cool"] },
        { "id": "heat_cool_vav",   "label": "Värme + Kyla + VAV (3-rörs/chilled beam)", "tags": ["vav_op", "vav_min", "vav_max", "vav_max_heat", "vav_min_stby", "vav_min_unocc"] },
        { "id": "heat_vav",        "label": "Värme + VAV",                            "tags": ["vav_op", "vav_min", "vav_max", "vav_max_heat"] },
        { "id": "vav_only",        "label": "Endast VAV",                             "tags": ["vav_op", "vav_min", "vav_max", "vav_min_stby", "vav_min_unocc", "vav_min_off"] },
        { "id": "co_vav",          "label": "Change-over + VAV",                      "tags": ["co_temp_pv", "co_state", "co_diff_heat", "co_diff_cool", "vav_op", "vav_min", "vav_max"] }
      ]
    },
    {
      "id": "temp_sensors",
      "type": "multiselect",
      "label": "Temperaturgivare (extra)",
      "help": "Inbyggd rumsgivare ingår alltid. Markera externa givare som finns på enheten.",
      "options": [
        { "id": "ext_room",   "label": "Extern rumsgivare (AI1/UI1, PT1000)",        "default": false, "tags": ["room_temp_ext"] },
        { "id": "supply_air", "label": "Tilluftsgivare (kaskadreglering)",           "default": false, "tags": ["supply_air_pv", "supply_air_csp", "supply_air_op", "supply_air_max_h", "supply_air_min_h", "supply_air_max_c", "supply_air_min_c", "supply_air_frost"] },
        { "id": "zone2",      "label": "Extra zon-givare (t.ex. golvvärme i badrum)", "default": false, "tags": ["zone2_temp_pv", "zone2_op", "zone2_sp", "zone2_enable"] },
        { "id": "int_room",   "label": "Intern givare separat (diagnostik)",         "default": false, "tags": ["room_temp_int"] }
      ]
    },
    {
      "id": "air_quality",
      "type": "multiselect",
      "label": "Luftkvalitet (CO₂)",
      "help": "Inbyggd CO₂: RCC-C3DOCS / RCC-C3HCS. Extern CO₂-ingång (AI2): RC-C3DOC / RC-C3DFOC. Övriga modeller saknar CO₂ — avmarkera då.",
      "options": [
        { "id": "co2",         "label": "CO₂-givare (inbyggd eller extern)",         "default": true,  "tags": ["co2_pv", "co2_hal", "co2_hi_sp"] },
        { "id": "co2_setpoints", "label": "CO₂-börvärden för VAV-styrning",          "default": true,  "tags": ["co2_sp_low", "co2_sp_high"] },
        { "id": "co2_presence", "label": "Närvarodetektering via CO₂",                "default": false, "tags": ["co2_presence_sp", "co2_presence_hy", "presence_co2"] }
      ]
    },
    {
      "id": "outputs",
      "type": "multiselect",
      "label": "Utgångar och regulatorvärden",
      "help": "Manuell-/Auto-styrning, manuella värden och min/max för värme, kyla och VAV. För 3-punkts-modeller (RC-CT/CTH/CTO/CDTO) saknas analoga utgångar — heat_op/cool_op visar då regulatorns interna behov i procent.",
      "options": [
        { "id": "heat_full",  "label": "Värmeutgång — manuell-läge och min-begränsning", "default": true,  "tags": ["heat_mode", "heat_man", "heat_min", "heat_pulse"] },
        { "id": "cool_full",  "label": "Kylutgång — manuell-läge",                      "default": true,  "tags": ["cool_mode", "cool_man", "cool_pulse"] },
        { "id": "vav_full",   "label": "VAV-utgång — manuell-läge och alla min/max",    "default": true,  "tags": ["vav_mode", "vav_man", "vav_min_off"] },
        { "id": "ec_fan",     "label": "EC-fläkt min/max begränsning (UO3)",           "default": false, "tags": ["ec_fan_min", "ec_fan_max"] }
      ]
    },
    {
      "id": "fan_control",
      "type": "dropdown",
      "label": "Fläktstyrning",
      "help": "EC-fläkt: alla …C3-modeller (analog 0-10 V på UO3). 3-stegs: -CF/-CFO/-CDFO (DO1-DO3 reläer, samma fan_state-register men annan fysisk routing). Ingen: 3-punkts-modellerna och övriga utan fläkt.",
      "default": "ec",
      "options": [
        { "id": "none",   "label": "Ingen fläktstyrning",                              "tags": [] },
        { "id": "ec",     "label": "EC-fläkt (analog 0-10 V på UO3)",                  "tags": ["fan_state", "fan_switch", "fan_select", "fan_ctrl_mode", "fan_speed_max"] },
        { "id": "step3",  "label": "3-stegs fläkt (DO1-DO3 reläer)",                   "tags": ["fan_state", "fan_switch", "fan_select", "fan_ctrl_mode", "fan_speed_max"] },
        { "id": "boost",  "label": "EC-fläkt med boost",                                "tags": ["fan_state", "fan_switch", "fan_select", "fan_ctrl_mode", "fan_speed_max", "fan_boost_time"] }
      ]
    },
    {
      "id": "operating_mode",
      "type": "multiselect",
      "label": "Driftläge & schemaläggning",
      "options": [
        { "id": "states_full",   "label": "Förvalt/frånslagsläge och bypass-tid",      "default": true,  "tags": ["preset_state", "shutdown_state", "bypass_time", "shutdown_cmd"] },
        { "id": "remote_state",  "label": "Centralstyrning (BMS-styrt driftläge)",     "default": true,  "tags": ["remote_state"] },
        { "id": "ctrl_mode_reg", "label": "Reglerläge-register (för diagnostik)",      "default": false, "tags": ["ctrl_mode"] },
        { "id": "unocc_setp",    "label": "Unoccupied-börvärden",                      "default": true,  "tags": ["sp_unocc_heat", "sp_unocc_cool"] },
        { "id": "standby",       "label": "Standby dödzon & frostskydd",               "default": true,  "tags": ["sp_standby_db", "sp_frost"] },
        { "id": "offset_limits", "label": "Begränsning av börvärdesförskjutning",      "default": false, "tags": ["sp_offset_max", "sp_offset_min"] },
        { "id": "pid_tuning",    "label": "PID-parametrar (P-band, I-tid)",            "default": false, "tags": ["pid_pband", "pid_itime"] }
      ]
    },
    {
      "id": "alarms",
      "type": "multiselect",
      "label": "Larm och givarfel",
      "options": [
        { "id": "room_temp_alarms", "label": "Hög/låg rumstemperatur",                  "default": true,  "tags": ["room_temp_hal", "room_temp_lal", "room_temp_hi_sp", "room_temp_lo_sp"] },
        { "id": "comm_fail",        "label": "Kommunikationsfel (rumstemp ej läst senaste 5 min)", "default": true, "tags": ["comm_fail_al"] },
        { "id": "window",           "label": "Fönsterkontakt",                          "default": false, "tags": ["window_al"] },
        { "id": "condense",         "label": "Kondensgivare (KG-A/1)",                  "default": false, "tags": ["condense_al"] },
        { "id": "run_ind",          "label": "Driftindikering från externt aggregat",   "default": false, "tags": ["run_indication"] }
      ]
    },
    {
      "id": "extra_features",
      "type": "multiselect",
      "label": "Extra funktioner",
      "options": [
        { "id": "lighting",      "label": "Belysningsstyrning (UO3 konfigurerad som lighting)", "default": false, "tags": ["lighting_v"] },
        { "id": "fan_indicator", "label": "Forcerad ventilation indikering",                   "default": false, "tags": ["forced_vent"] }
      ]
    }
  ]
